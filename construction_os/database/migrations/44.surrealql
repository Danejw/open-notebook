DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_region TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_region_page ON TABLE drawing_region COLUMNS page_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_region_run ON TABLE drawing_region COLUMNS run_id;

DEFINE TABLE IF NOT EXISTS drawing_item SCHEMAFULL;
