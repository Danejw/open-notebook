-- Migration 44: Architectural drawing extraction tables (opt-in, isolated from source_embedding)

DEFINE TABLE IF NOT EXISTS drawing_extraction_run SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS source_id ON TABLE drawing_extraction_run TYPE record<source>;
DEFINE FIELD IF NOT EXISTS project_id ON TABLE drawing_extraction_run TYPE option<record<project>>;
DEFINE FIELD IF NOT EXISTS file_hash ON TABLE drawing_extraction_run TYPE option<string>;
DEFINE FIELD IF NOT EXISTS extractor_version ON TABLE drawing_extraction_run TYPE string;
DEFINE FIELD IF NOT EXISTS extraction_model ON TABLE drawing_extraction_run TYPE option<string>;
DEFINE FIELD IF NOT EXISTS verification_model ON TABLE drawing_extraction_run TYPE option<string>;
DEFINE FIELD IF NOT EXISTS embedding_model ON TABLE drawing_extraction_run TYPE option<string>;
DEFINE FIELD IF NOT EXISTS status ON TABLE drawing_extraction_run TYPE string;
DEFINE FIELD IF NOT EXISTS active ON TABLE drawing_extraction_run TYPE bool DEFAULT false;
DEFINE FIELD IF NOT EXISTS force ON TABLE drawing_extraction_run TYPE bool DEFAULT false;
DEFINE FIELD IF NOT EXISTS command_id ON TABLE drawing_extraction_run TYPE option<record>;
DEFINE FIELD IF NOT EXISTS started_at ON TABLE drawing_extraction_run TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS finished_at ON TABLE drawing_extraction_run TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS errors ON TABLE drawing_extraction_run TYPE option<array>;
DEFINE FIELD IF NOT EXISTS page_count ON TABLE drawing_extraction_run TYPE option<int>;
DEFINE FIELD IF NOT EXISTS drawing_page_count ON TABLE drawing_extraction_run TYPE option<int>;
DEFINE FIELD IF NOT EXISTS stats ON TABLE drawing_extraction_run TYPE option<object>;
DEFINE FIELD IF NOT EXISTS output_dir ON TABLE drawing_extraction_run TYPE option<string>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_extraction_run TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_extraction_run TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_run_source ON TABLE drawing_extraction_run COLUMNS source_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_run_project ON TABLE drawing_extraction_run COLUMNS project_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_run_active ON TABLE drawing_extraction_run COLUMNS source_id, active;

DEFINE TABLE IF NOT EXISTS drawing_page SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS run_id ON TABLE drawing_page TYPE record<drawing_extraction_run>;
DEFINE FIELD IF NOT EXISTS source_id ON TABLE drawing_page TYPE record<source>;
DEFINE FIELD IF NOT EXISTS page_index ON TABLE drawing_page TYPE int;
DEFINE FIELD IF NOT EXISTS page_label ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS width ON TABLE drawing_page TYPE option<float>;
DEFINE FIELD IF NOT EXISTS height ON TABLE drawing_page TYPE option<float>;
DEFINE FIELD IF NOT EXISTS rotation ON TABLE drawing_page TYPE option<int>;
DEFINE FIELD IF NOT EXISTS is_drawing ON TABLE drawing_page TYPE option<bool>;
DEFINE FIELD IF NOT EXISTS discipline ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS sheet_number ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS sheet_title ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS drawing_types ON TABLE drawing_page TYPE option<array<string>>;
DEFINE FIELD IF NOT EXISTS classification_confidence ON TABLE drawing_page TYPE option<float>;
DEFINE FIELD IF NOT EXISTS page_kind ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS render_path ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS thumbnail_path ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS deterministic_evidence ON TABLE drawing_page TYPE option<object>;
DEFINE FIELD IF NOT EXISTS classification ON TABLE drawing_page TYPE option<object>;
DEFINE FIELD IF NOT EXISTS sheet_metadata ON TABLE drawing_page TYPE option<object>;
DEFINE FIELD IF NOT EXISTS raw_model_responses ON TABLE drawing_page TYPE option<object>;
DEFINE FIELD IF NOT EXISTS page_summary ON TABLE drawing_page TYPE option<string>;
DEFINE FIELD IF NOT EXISTS warnings ON TABLE drawing_page TYPE option<array>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_page TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_page TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_page_run ON TABLE drawing_page COLUMNS run_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_page_source ON TABLE drawing_page COLUMNS source_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_page_sheet ON TABLE drawing_page COLUMNS sheet_number;

DEFINE TABLE IF NOT EXISTS drawing_region SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS run_id ON TABLE drawing_region TYPE record<drawing_extraction_run>;
DEFINE FIELD IF NOT EXISTS page_id ON TABLE drawing_region TYPE record<drawing_page>;
DEFINE FIELD IF NOT EXISTS region_type ON TABLE drawing_region TYPE string;
DEFINE FIELD IF NOT EXISTS bbox_pdf ON TABLE drawing_region TYPE option<object>;
