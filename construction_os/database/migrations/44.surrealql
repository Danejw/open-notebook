DEFINE FIELD IF NOT EXISTS properties ON TABLE drawing_item TYPE option<object>;
DEFINE FIELD IF NOT EXISTS raw_text ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS bbox_pdf ON TABLE drawing_item TYPE option<object>;
DEFINE FIELD IF NOT EXISTS bbox_norm ON TABLE drawing_item TYPE option<object>;
DEFINE FIELD IF NOT EXISTS evidence_crop ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS confidence ON TABLE drawing_item TYPE option<float>;
DEFINE FIELD IF NOT EXISTS confidence_band ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS extraction_method ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS verification_status ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS model_version ON TABLE drawing_item TYPE option<string>;
DEFINE FIELD IF NOT EXISTS warnings ON TABLE drawing_item TYPE option<array>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_item TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_item TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_item_run ON TABLE drawing_item COLUMNS run_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_item_page ON TABLE drawing_item COLUMNS page_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_item_type ON TABLE drawing_item COLUMNS item_type;
DEFINE INDEX IF NOT EXISTS idx_drawing_item_stable ON TABLE drawing_item COLUMNS run_id, stable_id;

DEFINE TABLE IF NOT EXISTS drawing_relationship SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS run_id ON TABLE drawing_relationship TYPE record<drawing_extraction_run>;
DEFINE FIELD IF NOT EXISTS source_id ON TABLE drawing_relationship TYPE record<source>;
DEFINE FIELD IF NOT EXISTS relationship_type ON TABLE drawing_relationship TYPE string;
DEFINE FIELD IF NOT EXISTS from_item_id ON TABLE drawing_relationship TYPE option<string>;
DEFINE FIELD IF NOT EXISTS to_item_id ON TABLE drawing_relationship TYPE option<string>;
DEFINE FIELD IF NOT EXISTS from_label ON TABLE drawing_relationship TYPE option<string>;
DEFINE FIELD IF NOT EXISTS to_label ON TABLE drawing_relationship TYPE option<string>;
DEFINE FIELD IF NOT EXISTS properties ON TABLE drawing_relationship TYPE option<object>;
DEFINE FIELD IF NOT EXISTS confidence ON TABLE drawing_relationship TYPE option<float>;
DEFINE FIELD IF NOT EXISTS evidence ON TABLE drawing_relationship TYPE option<object>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_relationship TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_relationship TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_rel_run ON TABLE drawing_relationship COLUMNS run_id;

DEFINE TABLE IF NOT EXISTS drawing_semantic_record SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS run_id ON TABLE drawing_semantic_record TYPE record<drawing_extraction_run>;
DEFINE FIELD IF NOT EXISTS project_id ON TABLE drawing_semantic_record TYPE option<record<project>>;
DEFINE FIELD IF NOT EXISTS source_id ON TABLE drawing_semantic_record TYPE record<source>;
DEFINE FIELD IF NOT EXISTS page_id ON TABLE drawing_semantic_record TYPE option<record<drawing_page>>;
DEFINE FIELD IF NOT EXISTS record_type ON TABLE drawing_semantic_record TYPE string;
DEFINE FIELD IF NOT EXISTS title ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS content ON TABLE drawing_semantic_record TYPE string;
DEFINE FIELD IF NOT EXISTS discipline ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS sheet_number ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS drawing_type ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS item_ids ON TABLE drawing_semantic_record TYPE option<array<string>>;
DEFINE FIELD IF NOT EXISTS region_id ON TABLE drawing_semantic_record TYPE option<record<drawing_region>>;
DEFINE FIELD IF NOT EXISTS confidence ON TABLE drawing_semantic_record TYPE option<float>;
DEFINE FIELD IF NOT EXISTS confidence_band ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS verification_status ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS bbox_norm ON TABLE drawing_semantic_record TYPE option<object>;
DEFINE FIELD IF NOT EXISTS evidence_crop ON TABLE drawing_semantic_record TYPE option<string>;
DEFINE FIELD IF NOT EXISTS metadata ON TABLE drawing_semantic_record TYPE option<object>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_semantic_record TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_semantic_record TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_semantic_run ON TABLE drawing_semantic_record COLUMNS run_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_semantic_project ON TABLE drawing_semantic_record COLUMNS project_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_semantic_type ON TABLE drawing_semantic_record COLUMNS record_type;

DEFINE TABLE IF NOT EXISTS drawing_embedding SCHEMAFULL;
DEFINE FIELD IF NOT EXISTS run_id ON TABLE drawing_embedding TYPE record<drawing_extraction_run>;
DEFINE FIELD IF NOT EXISTS project_id ON TABLE drawing_embedding TYPE option<record<project>>;
DEFINE FIELD IF NOT EXISTS source_id ON TABLE drawing_embedding TYPE record<source>;
DEFINE FIELD IF NOT EXISTS page_id ON TABLE drawing_embedding TYPE option<record<drawing_page>>;
DEFINE FIELD IF NOT EXISTS region_id ON TABLE drawing_embedding TYPE option<record<drawing_region>>;
DEFINE FIELD IF NOT EXISTS semantic_record_id ON TABLE drawing_embedding TYPE option<record<drawing_semantic_record>>;
DEFINE FIELD IF NOT EXISTS item_ids ON TABLE drawing_embedding TYPE option<array<string>>;
DEFINE FIELD IF NOT EXISTS content ON TABLE drawing_embedding TYPE string;
DEFINE FIELD IF NOT EXISTS record_type ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS discipline ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS sheet_number ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS drawing_type ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS confidence ON TABLE drawing_embedding TYPE option<float>;
DEFINE FIELD IF NOT EXISTS verification_status ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS embedding_model ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS embedding ON TABLE drawing_embedding TYPE array<float>;
DEFINE FIELD IF NOT EXISTS image_path ON TABLE drawing_embedding TYPE option<string>;
DEFINE FIELD IF NOT EXISTS image_embedding ON TABLE drawing_embedding TYPE option<array<float>>;
DEFINE FIELD IF NOT EXISTS created ON TABLE drawing_embedding TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS updated ON TABLE drawing_embedding TYPE option<datetime>;
DEFINE INDEX IF NOT EXISTS idx_drawing_emb_run ON TABLE drawing_embedding COLUMNS run_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_emb_project ON TABLE drawing_embedding COLUMNS project_id;
DEFINE INDEX IF NOT EXISTS idx_drawing_emb_source ON TABLE drawing_embedding COLUMNS source_id;

DEFINE EVENT IF NOT EXISTS source_delete_cleanup_drawing ON TABLE source WHEN ($after == NONE) THEN {
    DELETE drawing_embedding WHERE source_id = $before.id;
    DELETE drawing_semantic_record WHERE source_id = $before.id;
    DELETE drawing_relationship WHERE source_id = $before.id;
    DELETE drawing_item WHERE source_id = $before.id;
    DELETE drawing_region WHERE page_id IN (SELECT VALUE id FROM drawing_page WHERE source_id = $before.id);
    DELETE drawing_page WHERE source_id = $before.id;
    DELETE drawing_extraction_run WHERE source_id = $before.id;
};

RETURN true;
